# Runtime
APP_ENV=production
DATABASE_URL=sqlite:///./data/agent.db
QDRANT_PATH=./data/qdrant
AUTHORIZED_ROOTS=./knowledge

# Local embedding model (required for the default semantic search path)
EMBEDDING_BACKEND=bge
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=16

# Local answer-generation model. No API key is required.
LLM_BACKEND=qwen_transformers
LLM_MODEL_ID=Qwen/Qwen3-0.6B
LLM_MAX_NEW_TOKENS=256
LLM_PRELOAD=true
LLM_COMPLEX_QUESTION_ENABLED=true
MODEL_DOWNLOAD_REPOSITORY=Qwen/Qwen3-0.6B
MODEL_AUTO_DOWNLOAD=false

# Local cross-encoder reranker
RERANKER_ENABLED=false
RERANKER_MODEL=BAAI/bge-reranker-base
RERANKER_DEVICE=cpu

# Put downloaded Hugging Face model files here.
HUGGINGFACE_HOME=./models/huggingface

# OCR
OCR_ENABLED=true
OCR_MIN_TEXT_CHARS_PER_PAGE=40
OCR_RENDER_DPI=150

# PDF image extraction. Defaults to the application data directory / pdf-images.
PDF_EXTRACT_IMAGES=true
# PDF_IMAGE_OUTPUT_DIR=./data/pdf-images

PARSE_WORKERS=4
INGESTION_BATCH_SIZE=16
MAX_CHUNKS_PER_DOCUMENT=3
SIMPLE_CANDIDATE_TOP_K=6
