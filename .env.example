# Runtime
APP_ENV=production
DATABASE_URL=sqlite:///./data/agent.db
QDRANT_PATH=./data/qdrant
AUTHORIZED_ROOTS=./knowledge

# Local embedding model (required for the default semantic search path)
EMBEDDING_BACKEND=bge
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=8

# Local answer-generation model. No API key is required.
LLM_BACKEND=qwen_transformers
LLM_MODEL_ID=Qwen/Qwen3-0.6B
LLM_MAX_NEW_TOKENS=320

# Local cross-encoder reranker
RERANKER_ENABLED=true
RERANKER_MODEL=BAAI/bge-reranker-base
RERANKER_DEVICE=cpu

# Put downloaded Hugging Face model files here.
HUGGINGFACE_HOME=./models/huggingface

# OCR
OCR_ENABLED=true
