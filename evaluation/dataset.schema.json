{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["id", "question", "category", "expected_answer", "relevant_sources", "difficulty", "validated"],
  "properties": {
    "id": {"type": "string"},
    "question": {"type": "string"},
    "category": {"type": "string"},
    "expected_answer": {"type": "string"},
    "answer_aliases": {"type": "array", "items": {"type": "string"}},
    "relevant_sources": {"type": "array", "items": {"type": "object"}},
    "difficulty": {"type": "string"},
    "requires_multiple_sources": {"type": "boolean"},
    "validated": {"type": "boolean"},
    "notes": {"type": "string"}
  }
}
